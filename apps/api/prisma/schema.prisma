generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SHELTER
  BREEDER
  ADMIN
}

model User {
  id    String  @id @default(uuid())
  phone String? @unique
  vkId  String? @unique
  email String? @unique
  name  String?
  role  Role    @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
