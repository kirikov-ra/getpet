generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SHELTER_OWNER
  BREEDER
  ADMIN
}

enum PetStatus {
  AVAILABLE
  FOSTER
  ADOPTED
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum ConsentType {
  PDN_PROCESSING
  MARKETING
  DATA_SHARING_WITH_SHELTER
}

model User {
  id    String  @id @default(uuid())
  phone String? @unique @db.VarChar(20)
  email String? @unique @db.VarChar(255)
  vkId  String? @unique @db.VarChar(50)
  name  String? @db.VarChar(255)
  role  Role    @default(USER)

  pets      Pet[]
  shelters  Shelter[]
  consents  Consent[]
  favorites Favorite[]

  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  @@map("users")
}

model Consent {
  id     String      @id @default(uuid())
  userId String
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   ConsentType

  purpose String? @db.Text

  givenAt   DateTime  @default(now()) @db.Timestamptz(3)
  revokedAt DateTime? @db.Timestamptz(3)
  ip        String?   @db.VarChar(45)
  userAgent String?   @db.Text

  accessLogs PDNAccessLog[]

  @@unique([userId, type])
  @@map("consents")
}

model Shelter {
  id          String  @id @default(uuid())
  slug        String  @unique @db.VarChar(255)
  name        String  @db.VarChar(255)
  description String  @db.Text
  address     String  @db.VarChar(255)
  city        String  @db.VarChar(100)
  region      String? @db.VarChar(100)
  phone       String? @db.VarChar(20)
  website     String? @db.VarChar(255)
  logoUrl     String? @db.VarChar(255)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  pets Pet[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([city])
  @@map("shelters")
}

model Category {
  id   String @id @default(uuid())
  slug String @unique @db.VarChar(255)
  name String @db.VarChar(255)

  breeds Breed[]
  pets   Pet[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@map("categories")
}

model Breed {
  id   String @id @default(uuid())
  slug String @unique @db.VarChar(255)
  name String @db.VarChar(255)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  description     String   @db.Text
  characteristics Json?    @default("[]")
  photos          String[] @default([])

  pets Pet[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([categoryId])
  @@map("breeds")
}

model Pet {
  id     String @id @default(uuid())
  name   String @db.VarChar(255)
  gender Gender @default(UNKNOWN)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  breedId     String?
  breed       Breed?  @relation(fields: [breedId], references: [id])
  customBreed String? @db.VarChar(255)

  birthDate    DateTime? @db.Date
  weight       Float?
  height       Float?
  isSterilized Boolean   @default(false)
  isVaccinated Boolean   @default(false)
  chipNumber   String?   @db.VarChar(100)
  tags         Json?     @default("[]")

  description String  @db.Text
  city        String  @db.VarChar(100)
  region      String? @db.VarChar(100)
  address     String? @db.VarChar(255)

  status PetStatus @default(AVAILABLE)

  images    PetImage[]
  mainImage String?    @db.VarChar(255)

  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id])
  shelterId String?
  shelter   Shelter? @relation(fields: [shelterId], references: [id])

  favoritedBy Favorite[]

  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([categoryId, status])
  @@index([ownerId])
  @@index([shelterId])
  @@index([shelterId, status])
  @@index([city, region])
  @@map("pets")
}

model PetImage {
  id        String  @id @default(uuid())
  url       String  @db.VarChar(255)
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  petId String
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([petId])
  @@map("pet_images")
}

model Favorite {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId  String
  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([userId, petId])
  @@map("favorites")
}

model PDNAccessLog {
  id String @id @default(uuid())

  userId    String?
  subjectId String

  action     String  @db.VarChar(255)
  targetType String? @db.VarChar(50)

  consentId String?
  consent   Consent? @relation(fields: [consentId], references: [id])

  ip String? @db.VarChar(45)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@index([subjectId])
  @@map("pdn_access_logs")
}
